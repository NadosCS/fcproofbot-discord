# Required Discord and Apps Script configuration
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
APPS_SCRIPT_URL=https://script.google.com/macros/s/DEPLOYMENT_ID/exec
FCBOT_API_KEY=

# Optional Backblaze B2 proof-image uploads. Set all four values together.
# The endpoint and key values are shown in the Backblaze B2 dashboard.
# Endpoint example: https://s3.us-west-004.backblazeb2.com
B2_S3_ENDPOINT=
B2_BUCKET=
B2_KEY_ID=
B2_APPLICATION_KEY=

# Optional public CDN/custom-domain prefix. When omitted, the bot derives the
# public S3 URL from B2_BUCKET and B2_S3_ENDPOINT.
B2_PUBLIC_BASE_URL=

# Optional upload limits and timeouts.
PROOF_IMAGE_MAX_MB=10
PROOF_IMAGE_DOWNLOAD_TIMEOUT_MS=15000
PROOF_IMAGE_UPLOAD_TIMEOUT_MS=30000

# Check for direct/manual sheet edits every 15 minutes. Bot proof mutations
# update the in-memory autocomplete catalog immediately.
AUTOCOMPLETE_SYNC_MINUTES=15
